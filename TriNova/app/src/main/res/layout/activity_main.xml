<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#1A1A2E"
    android:orientation="vertical"
    tools:context=".MainActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#16213E"
        android:elevation="6dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TriNova Quiz"
            android:textColor="#E94560"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">


    <LinearLayout
        android:id="@+id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="#E94560" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Loading your trivia..."
            android:textColor="#AAAACC"
            android:textSize="16sp" />
    </LinearLayout>


    <ScrollView
        android:id="@+id/quizContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvQuestionProgress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#E94560"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Question 3/10" />

                <TextView
                    android:id="@+id/tvScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#0F3460"
                    android:textSize="14sp"
                    android:background="@drawable/score_badge_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    tools:text="Score: 2" />
            </LinearLayout>


            <ProgressBar
                android:id="@+id/quizProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginBottom="24dp"
                android:max="10"
                android:progress="3"
                android:progressDrawable="@drawable/quiz_progress_bar" />

            <TextView
                android:id="@+id/tvCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/category_badge_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginBottom="16dp"
                android:textColor="#E94560"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="GENERAL KNOWLEDGE" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#16213E"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <TextView
                    android:id="@+id/tvQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:textColor="#EAEAEA"
                    android:textSize="20sp"
                    android:lineSpacingExtra="6dp"
                    tools:text="What is the capital of France?" />

            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="16dp"
                android:textSize="16sp"
                android:textColor="#EAEAEA"
                android:textAllCaps="false"
                app:backgroundTint="#16213E"
                app:cornerRadius="16dp"
                app:strokeColor="#E94560"
                app:strokeWidth="1dp"
                tools:text="A. Paris" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="16dp"
                android:textSize="16sp"
                android:textColor="#EAEAEA"
                android:textAllCaps="false"
                app:backgroundTint="#16213E"
                app:cornerRadius="16dp"
                app:strokeColor="#E94560"
                app:strokeWidth="1dp"
                tools:text="B. London" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="16dp"
                android:textSize="16sp"
                android:textColor="#EAEAEA"
                android:textAllCaps="false"
                app:backgroundTint="#16213E"
                app:cornerRadius="16dp"
                app:strokeColor="#E94560"
                app:strokeWidth="1dp"
                tools:text="C. Berlin" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:padding="16dp"
                android:textSize="16sp"
                android:textColor="#EAEAEA"
                android:textAllCaps="false"
                app:backgroundTint="#16213E"
                app:cornerRadius="16dp"
                app:strokeColor="#E94560"
                app:strokeWidth="1dp"
                tools:text="D. Madrid" />

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/wrongAnswerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#CC1A1A2E"
        android:padding="32dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvRoastEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💀"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRoastTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wrong Answer!"
            android:textColor="#E94560"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvRoastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EAEAEA"
            android:textSize="16sp"
            android:gravity="center"
            android:textStyle="italic"
            android:layout_marginBottom="8dp"
            tools:text="Bro really said let me pick the wrongest answer" />

        <TextView
            android:id="@+id/tvCorrectAnswer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4CAF50"
            android:textSize="15sp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            tools:text="✅ Correct answer: Paris" />

        <androidx.cardview.widget.CardView
            android:layout_width="240dp"
            android:layout_height="240dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/ivSadDog"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#2A2A4A" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="This dog is disappointed in you too 🐕"
            android:textColor="#AAAACC"
            android:textSize="13sp"
            android:textStyle="italic" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere to continue"
            android:textColor="#666688"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>


    <LinearLayout
        android:id="@+id/correctAnswerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#CC1A1A2E"
        android:padding="32dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/tvHypeEmoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvHypeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correct!"
            android:textColor="#4CAF50"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvHypeMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#EAEAEA"
            android:textSize="16sp"
            android:gravity="center"
            android:textStyle="italic"
            android:layout_marginBottom="20dp"
            tools:text="YOOO you actually knew that?!" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#16213E"
            app:cardElevation="12dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your reward: a legendary dad joke 👴"
                    android:textColor="#E94560"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvDadJoke"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#EAEAEA"
                    android:textSize="18sp"
                    android:textStyle="italic"
                    android:lineSpacingExtra="4dp"
                    tools:text="Why did the scarecrow win an award? He was outstanding in his field." />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap anywhere to continue"
            android:textColor="#666688"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>


    <ScrollView
        android:id="@+id/ratingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="64sp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz Complete!"
                android:textColor="#E94560"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFinalScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EAEAEA"
                android:textSize="20sp"
                android:layout_marginBottom="40dp"
                tools:text="You scored 7/10!" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rate this quiz experience!"
                android:textColor="#AAAACC"
                android:textSize="18sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvRatingValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="#E94560"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRatingEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐱"
                android:textSize="36sp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/ratingSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1"
                android:valueTo="10"
                android:stepSize="1"
                android:value="5"
                app:thumbColor="#E94560"
                app:trackColorActive="#E94560"
                app:trackColorInactive="#2A2A4A"
                app:haloColor="#33E94560"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitRating"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Show Me a Cat! 🐱"
                android:textSize="18sp"
                android:textAllCaps="false"
                app:backgroundTint="#E94560"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>


    <ScrollView
        android:id="@+id/catResultContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp">

            <TextView
                android:id="@+id/tvCatMoodEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="64sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                tools:text="😻" />

            <TextView
                android:id="@+id/tvCatMoodMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#EAEAEA"
                android:textSize="18sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                tools:text="This cat absolutely LOVES your rating!" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivCatImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#2A2A4A" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvCatRatingInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAACC"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                tools:text="Your rating: 9/10 • Score: 7/10" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thanks for playing TriNova! 🎮"
                android:textColor="#E94560"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAgain"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Play Again 🔄"
                android:textSize="18sp"
                android:textAllCaps="false"
                app:backgroundTint="#E94560"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:id="@+id/errorContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="😵"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E94560"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            tools:text="Something went wrong!" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try Again"
            android:textAllCaps="false"
            app:backgroundTint="#E94560"
            app:cornerRadius="16dp" />

    </LinearLayout>

    </FrameLayout>
</LinearLayout>